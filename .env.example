# =====================================================
# Enterprise Agent v0.2 - Environment Configuration
# =====================================================

# Database
DATABASE_URL=postgresql://agent:agent_secret@127.0.0.1:5432/agent_db

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API Server
API_SERVER_URL=http://127.0.0.1:3001
API_SERVER_PORT=3001

# Agent Runtime
AGENT_RUNTIME_URL=http://127.0.0.1:8000
AGENT_RUNTIME_PORT=8000

# Model Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
DEEPSEEK_API_KEY=sk-...
ZHIPU_API_KEY=...
MOONSHOT_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...

# Default Provider & Model
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# SiliconFlow (OpenAI-compatible,国内易获取)
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/zai-org/GLM-4.7

# SiliconFlow Embedding
SILICONFLOW_EMBEDDING_API_KEY=sk-...
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_REPO=owner/repo

# GitLab
GITLAB_TOKEN=glpat-...
GITLAB_URL=https://gitlab.com

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Lark
LARK_APP_ID=cli_...
LARK_APP_SECRET=...
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_DEFAULT_CHAT_ID=...

# MCP
MCP_DEFAULT_SERVER=filesystem

# Security
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
ENCRYPTION_KEY=change-this-to-another-random-string-32-chars

# Logging
LOG_LEVEL=INFO

# Adapters
USE_REAL_ADAPTERS=false

# Artifacts directory (local development)
ARTIFACTS_DIR=/tmp/agent_artifacts
